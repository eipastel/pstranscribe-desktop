# .env.example — SÓ para dev/teste local.
#
# O usuário final NÃO usa .env: a chave da OpenAI é digitada dentro do app e
# guardada criptografada com safeStorage. Nada aqui afeta o build de produção.
#
# Copie para `.env` (git-ignore) se precisar sobrescrever algo localmente.

# URL do renderer em modo dev. O electron-vite injeta isso automaticamente ao
# rodar `npm run dev` — só defina manualmente se estiver servindo o renderer
# em outra porta/host. Em produção é ignorado.
# ELECTRON_RENDERER_URL=http://localhost:5173
